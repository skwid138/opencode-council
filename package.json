{
  "name": "@skwid138/opencode-council",
  "version": "0.3.0",
  "description": "Multi-model adversarial review council plugin for opencode",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/index.js"
    }
  },
  "files": [
